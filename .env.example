# Copy this file to `.env` and fill in real values.
# .env is gitignored — never commit real secrets.

# --- Google Gemini ---
# Get an API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Optional: override the default Gemini model
# GEMINI_MODEL=gemini-2.5-flash

# --- Telegram editorial bot ---
# Token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram user IDs allowed to use admin features.
# Get your numeric ID from @userinfobot (e.g. 123456789,987654321)
ALLOWED_ADMIN_IDS=your_telegram_user_id_here

# Legacy single-admin fallback (used only when ALLOWED_ADMIN_IDS is empty)
TELEGRAM_ADMIN_CHAT_ID=your_chat_id_here

# Public channel where approved articles are broadcast.
# Either @username for public channels, or the numeric id (e.g. -1001234567890).
# The bot MUST be an administrator of this channel with "Post Messages" enabled.
TELEGRAM_PUBLIC_CHANNEL_ID=@YourPublicChannel

# --- Khabar Varzeshi newsroom (site publishing automation) ---
NEWSROOM_USERNAME=your_newsroom_username
NEWSROOM_PASSWORD=your_newsroom_password

# Optional overrides (defaults shown)
# NEWSROOM_LOGIN_URL=https://newsroom.khabarvarzeshi.com/login/login.xhtml
# NEWSROOM_CREATE_URL=https://newsroom.khabarvarzeshi.com/news.xhtml
# NEWSROOM_HEADLESS=1
# SELENIUM_WAIT_TIMEOUT=25
# SELENIUM_LOGIN_WAIT_TIMEOUT=30
# SELENIUM_CKEDITOR_WAIT_TIMEOUT=45

# --- Semantic deduplication (incoming RSS vs Khabar Varzeshi last 24h) ---
# Enabled by default. Uses Gemini embeddings (same GEMINI_API_KEY).
# SEMANTIC_DEDUP_ENABLED=1
# SEMANTIC_DEDUP_BASELINE_RSS=https://www.khabarvarzeshi.com/rss
# SEMANTIC_DEDUP_EMBEDDING_MODEL=gemini-embedding-001
# SEMANTIC_DEDUP_THRESHOLD=0.80
# SEMANTIC_DEDUP_DIMENSIONS=768
# SEMANTIC_DEDUP_LOOKBACK_HOURS=24
# If embeddings fail, fail-open continues ingestion (set 0 to block instead).
# SEMANTIC_DEDUP_FAIL_OPEN=1
# Free-tier rate-limit pacing (~100 embed requests/minute):
# SEMANTIC_DEDUP_REQUEST_INTERVAL=1.2
# SEMANTIC_DEDUP_BATCH_SIZE=8
# SEMANTIC_DEDUP_BATCH_PAUSE=2.0
# SEMANTIC_DEDUP_MAX_RETRIES=5
# SEMANTIC_DEDUP_RETRY_BASE_DELAY=12
# SEMANTIC_DEDUP_RETRY_MAX_DELAY=60
